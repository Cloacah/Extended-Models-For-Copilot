{
	"compilerOptions": {
		"module": "Node16",
		"moduleResolution": "Node16",
		"target": "ES2022",
		"lib": [
			"ES2022",
			"DOM"
		],
		"rootDir": "src",
		"outDir": "out",
		"sourceMap": true,
		"strict": true,
		"skipLibCheck": true,
		"types": [
			"node"
		]
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"out"
	]
}
